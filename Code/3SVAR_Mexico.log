> ──
. global wdir `"C:/Users/carlo/OneDrive - INSTITUTO TECNOLOGICO AUTONOMO DE MEX
> ICO/Escritorio/varras"'

. global ddir "$wdir/raw data"

. global fdir "$wdir/figures"

. global cdir "$wdir/Code"

. 
. capture mkdir "$fdir"

. cd "$ddir"
