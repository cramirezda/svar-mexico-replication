. * ── 1.1 Augmented Dickey-Fuller (HO: raíz unitaria) ─────────────────────
. di as txt _newline "--- 1.1 ADF Test (HO: raíz unitaria) ---"

--- 1.1 ADF Test (HO: raíz unitaria) ---

. foreach v in igae pi_core_gap pi_inpp_gap dep_tcr i_gap m2_gap ///
>              y_us_gap pi_us pi_crb {
  2.     di as txt _newline "  Variable: `v'"
  3.     quietly dfuller `v', lags(3) regress
  4.     di as res "  ADF stat = " %8.4f `r(Zt)' "  p-valor aprox.: " ///
>               cond(`r(Zt)' < -3.45, "< 0.01", cond(`r(Zt)' < -2.89, "< 0.05",
>  "> 0.05"))
  5. }

