fit_multi <- multinom(rating_group ~ duration + log_budget + Z_FBlikes + D_USA + D_UK, data = df_model)
library(tidyverse)
library(nnet)       # Para multinom (Logit Multinomial)
library(MASS)       # Para polr (Probit Ordenado)
library(caret)      # Para matrices de confusión
df_model <- df %>%
mutate(
rating_group = factor(content_rating %>% trimws() %>%
recode("G"="Family-Friendly", "TV-G"="Family-Friendly", "TV-Y"="Family-Friendly",
"TV-Y7"="Family-Friendly", "Approved"="Family-Friendly", "Passed"="Family-Friendly",
"PG"="Mild Guidance", "TV-PG"="Mild Guidance", "GP"="Mild Guidance", "M"="Mild Guidance",
"PG-13"="Teen / Moderate", "TV-14"="Teen / Moderate",
"R"="Adult Content", "NC-17"="Adult Content", "X"="Adult Content", "TV-MA"="Adult Content"),
levels = c("Family-Friendly", "Mild Guidance", "Teen / Moderate", "Adult Content")),
log_budget = log(budget),
D_USA = as.numeric(country == "USA"),
D_UK = as.numeric(country == "UK"),
Z_FBlikes = as.vector(scale(movie_facebook_likes))
) %>%
filter(!is.na(rating_group), !is.na(log_budget), !is.na(duration))
# -------------------------------------------------------------------------
# c) Matriz de Confusión (Logit Multinomial)
# -------------------------------------------------------------------------
fit_multi <- multinom(rating_group ~ duration + log_budget + Z_FBlikes + D_USA + D_UK, data = df_model)
# Predicciones de clase
preds_multi <- predict(fit_multi)
conf_matrix <- confusionMatrix(preds_multi, df_model$rating_group)
print("Matriz de Confusión - Logit Multinomial:")
print(conf_matrix$table)
cat("\nPorcentaje de clasificación correcta global:", conf_matrix$overall['Accuracy'] * 100, "%\n")
# -------------------------------------------------------------------------
# d) Elasticidad (Adult Content vs Budget)
# -------------------------------------------------------------------------
# Calculamos la probabilidad predicha para cada observación
probs <- as.data.frame(predict(fit_multi, type = "probs"))
# Coeficientes de log_budget para cada nivel (el primero es 0 por ser base)
beta_logB <- c("Family-Friendly" = 0, coef(fit_multi)[, "log_budget"])
# Cálculo de la elasticidad individual: beta_j - sum(P_k * beta_k)
# Dado que Budget está en log, la elasticidad wrt Budget es dP/dlogB * (1/P)
# En multinomial logit: dPj/dlogB = Pj * (beta_j - mean_beta)
# Elasticidad = (dPj/dlogB) / Pj = beta_j - sum(probs * betas)
sum_p_beta <- as.matrix(probs) %*% beta_logB
elasticidades_adult <- beta_logB["Adult Content"] - sum_p_beta
cat("\nElasticidad Promedio (Adult Content vs Budget):", mean(elasticidades_adult), "\n")
# -------------------------------------------------------------------------
# e) Probit Ordenado y Efecto Parcial (Reducción 15 min en duración)
# -------------------------------------------------------------------------
fit_ordered <- polr(rating_group ~ duration + log_budget + Z_FBlikes + D_USA + D_UK,
data = df_model, method = "probit")
# Probabilidades originales
prob_orig <- predict(fit_ordered, type = "probs")[, "Teen / Moderate"]
# Probabilidades con duración reducida en 15 minutos
df_reduced <- df_model %>% mutate(duration = duration - 15)
prob_reduced <- predict(fit_ordered, newdata = df_reduced, type = "probs")[, "Teen / Moderate"]
# Efecto Parcial Promedio (APE)
ape_duration <- mean(prob_reduced - prob_orig)
cat("\nEfecto Parcial Promedio (Reducción 15 min en duración para Teen/Moderate):", ape_duration, "\n")
View(widgets)
# ==============================================================================
# Replicación Carrillo & Elizondo (2015) - Descarga de Datos
# Herramienta: R
# ==============================================================================
# 1. Instalar y cargar las librerías necesarias
# install.packages(c("siebanxicor", "fredr", "dplyr", "lubridate", "mFilter", "tidyr"))
library(siebanxicor)
rm(list=ls())
setwd("C:/Users/carlo/OneDrive - INSTITUTO TECNOLOGICO AUTONOMO DE MEXICO/Escritorio/varras/raw data")
#Sys.setlocale("LC_TIME", "Spanish")
paquetes <- c("dplyr", "readxl", "stringr", "tidyverse", "readr",'stringi',
"ggplot2",  "openxlsx", "lubridate",'mFilter','tseries','purrr','vars')
sapply(paquetes, function(p) if (!require(p, character.only = TRUE)) install.packages(p, dependencies = TRUE))
df_final <- read_excel('database.xlsx')
# ==============================================================================
# ESTIMACIÓN DEL SVAR: RESTRICCIONES DE EXCLUSIÓN (CHOLESKY)
# ==============================================================================
# 1. Definición de los bloques del modelo
# El ordenamiento es crítico para Cholesky (de variables más lentas a más rápidas)
endogenas_mat <- df_final %>%
dplyr::select(igae, pi_core_gap, pi_inpp_gap, m2_gap, i_gap, dep_tcr) %>%
mutate_all(as.numeric) %>%
as.matrix()
exogenas_mat <- df_final %>%
dplyr::select(y_us_gap, pi_us, pi_crb) %>%
mutate_all(as.numeric) %>%
as.matrix()
# 2. Estimación del VAR en Forma Reducida
# Se utilizan 3 rezagos (p=3) como se indica en la metodología empírica para México
var_reducido <- VAR(y = endogenas_mat,
p = 3,
type = "const",
exogen = exogenas_mat)
summary(var_reducido)
# Revisión rápida de la estabilidad del sistema (las raíces deben ser < 1)
roots(var_reducido)
# 3. Identificación del Choque Estructural (Política Monetaria)
# Calculamos la IRF para un choque (impulso) en la tasa de interés (i_gap)
# Se utilizan 2,000 iteraciones de bootstrap para los intervalos de confianza
irf_mp_shock <- irf(var_reducido,
impulse = "i_gap",
response = c("igae", "pi_core_gap", "pi_inpp_gap", "dep_tcr",'i_gap','m2_gap'),
n.ahead = 24,       # Horizonte de 24 meses
ortho = TRUE,       # ortho = TRUE aplica la descomposición de Cholesky
boot = TRUE,
runs = 2000,
ci = 0.68)          # Intervalos de confianza al 68% (un estándar en SVARs)
# 4. Visualización de las Funciones Impulso-Respuesta
# Ajustamos los márgenes del gráfico para una mejor visualización
par(mfrow = c(2, 3))
plot(irf_mp_shock, main = "Respuesta a un choque de Política Monetaria (Cholesky)")
plot(irf_mp_shock, main = "Respuesta a un choque de Política Monetaria (Cholesky)")
par(mfrow = c(2, 3), mar = c(4, 4, 3, 1), oma = c(0, 0, 2, 0))
# Al graficar un objeto IRF con múltiples respuestas, plot() lo hace automáticamente.
# plot.type = "single" asegura que los intervalos de confianza aparezcan en el mismo eje.
plot(irf_mp_shock, plot.type = "single",
main = "Choque en i_gap",
xlab = "Meses",
ylab = "Desviación")
plot(irf_mp_shock, plot.type = "single",
xlab = "Meses",
ylab = "Desviación")
# plot.type = "single" asegura que los intervalos de confianza aparezcan en el mismo eje.
plot(irf_mp_shock, plot.type = "single")
# plot.type = "single" asegura que los intervalos de confianza aparezcan en el mismo eje.
plot(irf_mp_shock), plot.type = "single")
plot(irf_mp_shock)
# Al graficar un objeto IRF con múltiples respuestas, plot() lo hace automáticamente.
# plot.type = "single" asegura que los intervalos de confianza aparezcan en el mismo eje.
plot(irf_mp_shock, plot.type = "single")
# Lista de variables que quieres visualizar
vars_to_plot <- c("igae", "pi_core_gap", "pi_inpp_gap", "dep_tcr", "i_gap", "m2_gap")
for(v in vars_to_plot){
# Extraemos la respuesta y los intervalos de confianza
# Nota: irf_mp_shock$irf$i_gap accede a la respuesta ante el choque de la tasa
resp <- irf_mp_shock$irf$i_gap[, v]
low  <- irf_mp_shock$Lower$i_gap[, v]
upp  <- irf_mp_shock$Upper$i_gap[, v]
# Calculamos los límites del eje Y para que la gráfica no se vea "pequeña"
# Le damos un margen de 10% adicional arriba y abajo
y_lims <- c(min(low) - 0.1 * abs(min(low)), max(upp) + 0.1 * abs(max(upp)))
# Graficamos la respuesta principal
plot(resp, type = "l", lwd = 2, col = "blue",
ylim = y_lims,
main = paste("Respuesta de:", v),
xlab = "Meses", ylab = "Desviación",
frame.plot = FALSE) # Estética más limpia
# Dibujamos los intervalos de confianza (bootstrapping 68%)
lines(low, col = "red", lty = 2)
lines(upp, col = "red", lty = 2)
# Línea de referencia en cero para ver si el efecto es significativo
abline(h = 0, col = "black", lwd = 1, lty = 3)
}
# Título global para el panel
mtext("SVAR: Funciones Impulso-Respuesta (Identificación Cholesky)",
side = 3, outer = TRUE, cex = 1.2, font = 2)
# 1. Extracción de datos para el IGAE
# ----------------------------------------------------------------
pasos <- 0:24  # Horizonte de tiempo (n.ahead)
# Extraemos la respuesta media y los intervalos de confianza del objeto irf_mp_shock
resp_igae <- irf_mp_shock$irf$i_gap[, "igae"]
low_igae  <- irf_mp_shock$Lower$i_gap[, "igae"]
upp_igae  <- irf_mp_shock$Upper$i_gap[, "igae"]
# 2. Creación del gráfico individual
# ----------------------------------------------------------------
# Ajustamos márgenes para un solo gráfico grande
par(mfrow = c(1, 1), mar = c(5, 5, 4, 2))
plot(pasos, resp_igae, type = "l", lwd = 3, col = "darkblue",
ylim = c(min(low_igae) - 0.05, max(upp_igae) + 0.05),
main = "Respuesta del IGAE ante un choque de Política Monetaria",
xlab = "Meses después del choque",
ylab = "Desviación porcentual (%)",
panel.first = grid()) # Agrega una cuadrícula de fondo
# Añadir el área sombreada para el intervalo de confianza (opcional pero profesional)
polygon(c(pasos, rev(pasos)), c(low_igae, rev(upp_igae)),
col = rgb(1, 0, 0, 0.2), border = NA)
# Líneas de confianza y línea de cero
lines(pasos, low_igae, col = "red", lty = 2, lwd = 1.5)
lines(pasos, upp_igae, col = "red", lty = 2, lwd = 1.5)
abline(h = 0, col = "black", lwd = 2)
# Configuramos la cuadrícula 2x3 y márgenes limpios
par(mfrow = c(2, 3), mar = c(4, 4, 3, 1), oma = c(0, 0, 2, 0))
# Lista de variables que quieres visualizar
vars_to_plot <- c("igae", "pi_core_gap", "pi_inpp_gap", "dep_tcr", "i_gap", "m2_gap")
for(v in vars_to_plot){
# Extraemos la respuesta y los intervalos de confianza
# Nota: irf_mp_shock$irf$i_gap accede a la respuesta ante el choque de la tasa
resp <- irf_mp_shock$irf$i_gap[, v]
low  <- irf_mp_shock$Lower$i_gap[, v]
upp  <- irf_mp_shock$Upper$i_gap[, v]
# Calculamos los límites del eje Y para que la gráfica no se vea "pequeña"
# Le damos un margen de 10% adicional arriba y abajo
y_lims <- c(min(low) - 0.1 * abs(min(low)), max(upp) + 0.1 * abs(max(upp)))
# Graficamos la respuesta principal
plot(resp, type = "l", lwd = 2, col = "blue",
ylim = y_lims,
main = paste("Respuesta de:", v),
xlab = "Meses", ylab = "Desviación",
frame.plot = FALSE) # Estética más limpia
# Dibujamos los intervalos de confianza (bootstrapping 68%)
lines(low, col = "red", lty = 2)
lines(upp, col = "red", lty = 2)
# Línea de referencia en cero para ver si el efecto es significativo
abline(h = 0, col = "black", lwd = 1, lty = 3)
}
# Título global para el panel
mtext("SVAR: Funciones Impulso-Respuesta (Identificación Cholesky)",
side = 3, outer = TRUE, cex = 1.2, font = 2)
