y = "Likes (Escala Pseudo-Log)") +
theme_minimal() + theme(legend.position = "none")
# Cargar librerías necesarias
library(tidyverse)
library(stargazer)
# 1. Cargar la base de datos
df <- read.csv("C:/Users/carlo/OneDrive - INSTITUTO TECNOLOGICO AUTONOMO DE MEXICO/Escritorio/RA/t2/movie_metadata_training.csv", stringsAsFactors = FALSE)
# -------------------------------------------------------------------------
# GENERACIÓN DE COLUMNA DE CLASIFICACIÓN (ROBUSTA)
# -------------------------------------------------------------------------
# Definimos los vectores de categorías para el mapeo
family_friendly <- c("G", "TV-G", "TV-Y", "TV-Y7", "Approved", "Passed")
mild_guidance   <- c("PG", "TV-PG", "GP", "M")
teen_moderate   <- c("PG-13", "TV-14")
adult_content   <- c("R", "NC-17", "X", "TV-MA")
# Limpieza y clasificación:
# - trimws() elimina espacios accidentales.
# - case_when() para asignar los grupos.
# - Se filtran automáticamente Unrated/Not Rated al no incluirlos o asignarles NA.
df_clean <- df %>%
mutate(content_rating = trimws(content_rating)) %>%
mutate(rating_group = case_when(
content_rating %in% family_friendly ~ "Family-Friendly",
content_rating %in% mild_guidance   ~ "Mild Guidance",
content_rating %in% teen_moderate   ~ "Teen / Moderate",
content_rating %in% adult_content   ~ "Adult Content",
TRUE ~ NA_character_
)) %>%
# Excluir los que no entraron en las categorías (incluye Unrated y Not Rated)
filter(!is.na(rating_group)) %>%
# Convertir a factor con orden lógico para las gráficas
mutate(rating_group = factor(rating_group,
levels = c("Family-Friendly", "Mild Guidance",
"Teen / Moderate", "Adult Content")))
# -------------------------------------------------------------------------
# INCISO A: DISTRIBUCIÓN
# -------------------------------------------------------------------------
# Tabla de frecuencias
tabla_distribucion <- df_clean %>%
count(rating_group) %>%
mutate(porcentaje = n / sum(n) * 100)
print(tabla_distribucion)
# Gráfica de distribución
ggplot(df_clean, aes(x = rating_group, fill = rating_group)) +
geom_bar() +
labs(title = "Distribución de Películas por Clasificación",
x = "Clasificación", y = "Número de Películas") +
theme_minimal() +
theme(legend.position = "none")
# -------------------------------------------------------------------------
# INCISO B: RELACIONES
# -------------------------------------------------------------------------
# i) Relación con Duration (Duración)
ggplot(df_clean, aes(x = rating_group, y = duration, fill = rating_group)) +
geom_boxplot() +
labs(title = "Relación: Clasificación vs Duración",
y = "Minutos") +
theme_minimal() + theme(legend.position = "none")
# ii) Relación con Budget (Presupuesto) - Usando escala logarítmica
ggplot(df_clean, aes(x = rating_group, y = budget, fill = rating_group)) +
geom_boxplot() +
scale_y_log10() +
labs(title = "Relación: Clasificación vs Presupuesto",
subtitle = "Escala Logarítmica", y = "Presupuesto") +
theme_minimal() + theme(legend.position = "none")
# iii) Relación con Movie Facebook Likes
ggplot(df_clean, aes(x = rating_group, y = movie_facebook_likes, fill = rating_group)) +
geom_boxplot() +
scale_y_continuous(trans = 'pseudo_log') + # Útil para datos con muchos ceros y sesgo
labs(title = "Relación: Clasificación vs Facebook Likes",
y = "Likes (Escala Pseudo-Log)") +
theme_minimal() + theme(legend.position = "none")
# iv) Relación con Country (País) - Mostrando los 5 países principales
top_countries <- df_clean %>%
count(country) %>%
top_n(5, n) %>%
pull(country)
df_clean %>%
filter(country %in% top_countries) %>%
ggplot(aes(x = country, fill = rating_group)) +
geom_bar(position = "fill") + # Barras apiladas al 100%
labs(title = "Composición de Clasificaciones por País (Top 5)",
y = "Proporción", x = "País", fill = "Clasificación") +
theme_minimal()
# 1. Preparación de datos (incluyendo transformaciones solicitadas)
df_model <- df_clean %>%
mutate(
# Variable dependiente para Columna (4)
y_adult = as.numeric(rating_group == "Adult Content"),
# Variables independientes transformadas
log_budget = log(budget),
D_UK = as.numeric(country == "UK"),
Z_FBlikes = as.vector(scale(movie_facebook_likes))
) %>%
# Limpiar NAs para que los modelos sean comparables
filter(!is.na(log_budget), !is.na(duration), !is.na(Z_FBlikes))
# 2. Estimación de los modelos (Columnas 1 a 4)
# Nota: La pregunta pide interpretar la Columna (4)
m1 <- glm(as.numeric(rating_group == "Family-Friendly") ~ duration + log_budget + D_UK + Z_FBlikes,
family = binomial(link = "logit"), data = df_model)
m2 <- glm(as.numeric(rating_group == "Mild Guidance") ~ duration + log_budget + D_UK + Z_FBlikes,
family = binomial(link = "logit"), data = df_model)
m3 <- glm(as.numeric(rating_group == "Teen / Moderate") ~ duration + log_budget + D_UK + Z_FBlikes,
family = binomial(link = "logit"), data = df_model)
m4 <- glm(y_adult ~ duration + log_budget + D_UK + Z_FBlikes,
family = binomial(link = "logit"), data = df_model)
# Mostrar resultados en tabla
stargazer(m1, m2, m3, m4, type = "text",
column.labels = c("Family", "Mild", "Teen", "Adult"))
