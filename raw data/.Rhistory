df <- read.csv("C:/Users/carlo/OneDrive - INSTITUTO TECNOLOGICO AUTONOMO DE MEXICO/Escritorio/RA/t2/movie_metadata_training.csv", stringsAsFactors = FALSE)
# -------------------------------------------------------------------------
# GENERACIÓN DE COLUMNA DE CLASIFICACIÓN (ROBUSTA)
# -------------------------------------------------------------------------
# Definimos los vectores de categorías para el mapeo
family_friendly <- c("G", "TV-G", "TV-Y", "TV-Y7", "Approved", "Passed")
mild_guidance   <- c("PG", "TV-PG", "GP", "M")
teen_moderate   <- c("PG-13", "TV-14")
adult_content   <- c("R", "NC-17", "X", "TV-MA")
# Limpieza y clasificación:
# - trimws() elimina espacios accidentales.
# - case_when() para asignar los grupos.
# - Se filtran automáticamente Unrated/Not Rated al no incluirlos o asignarles NA.
df_clean <- df %>%
mutate(content_rating = trimws(content_rating)) %>%
mutate(rating_group = case_when(
content_rating %in% family_friendly ~ "Family-Friendly",
content_rating %in% mild_guidance   ~ "Mild Guidance",
content_rating %in% teen_moderate   ~ "Teen / Moderate",
content_rating %in% adult_content   ~ "Adult Content",
TRUE ~ NA_character_
)) %>%
# Excluir los que no entraron en las categorías (incluye Unrated y Not Rated)
filter(!is.na(rating_group)) %>%
# Convertir a factor con orden lógico para las gráficas
mutate(rating_group = factor(rating_group,
levels = c("Family-Friendly", "Mild Guidance",
"Teen / Moderate", "Adult Content")))
# 1. Preparación de datos y Feature Engineering
df_reto <- df_clean %>%
mutate(
# Variables de base
log_budget = log(budget),
D_USA = as.numeric(country == "USA"),
D_UK = as.numeric(country == "UK"),
Z_FBlikes = as.vector(scale(movie_facebook_likes)),
# NUEVAS VARIABLES (Propuesta)
is_Horror = as.numeric(grepl("Horror", genres)),
is_Animation = as.numeric(grepl("Animation", genres)),
faces = ifelse(is.na(facenumber_in_poster), 0, facenumber_in_poster),
# FORMAS FUNCIONALES (Interacciones)
inter_anim_budget = is_Animation * log_budget,
inter_horror_dur  = is_Horror * duration
) %>%
# Limpiar filas con NAs en las variables utilizadas
filter(!is.na(log_budget), !is.na(duration), !is.na(title_year))
# 2. Estimación del Modelo Logit Multinomial (Mejorado)
modelo_reto <- multinom(rating_group ~ duration + log_budget + Z_FBlikes +
D_USA + D_UK + title_year + faces +
is_Horror + is_Animation +
inter_anim_budget + inter_horror_dur,
data = df_reto, MaxNWts = 2000)
# 3. Resultados y Matriz de Confusión
summary(modelo_reto)
# Predicciones
predicciones <- predict(modelo_reto, newdata = df_reto)
# Generar Matriz de Confusión
matriz_conf <- confusionMatrix(predicciones, df_reto$rating_group)
print(matriz_conf)
# Extraer el Accuracy (para verificar la mejora)
cat("Precisión del modelo (Accuracy):", matriz_conf$overall['Accuracy'], "\n")
library(tidyverse)
library(stargazer)
# Preparación de variables
df_logit <- df_clean %>%
mutate(
log_budget = log(budget),
D_USA = as.numeric(country == "USA"),
D_UK = as.numeric(country == "UK"),
Z_FBlikes = as.vector(scale(movie_facebook_likes)),
y1 = as.numeric(rating_group == "Family-Friendly"),
y2 = as.numeric(rating_group == "Mild Guidance"),
y3 = as.numeric(rating_group == "Teen / Moderate"),
y4 = as.numeric(rating_group == "Adult Content")
) %>%
filter(!is.na(log_budget), !is.na(duration))
# Estimación de los 4 modelos
fit1 <- glm(y1 ~ duration + log_budget + Z_FBlikes + D_USA + D_UK, data = df_logit, family = binomial)
fit2 <- glm(y2 ~ duration + log_budget + Z_FBlikes + D_USA + D_UK, data = df_logit, family = binomial)
fit3 <- glm(y3 ~ duration + log_budget + Z_FBlikes + D_USA + D_UK, data = df_logit, family = binomial)
fit4 <- glm(y4 ~ duration + log_budget + Z_FBlikes + D_USA + D_UK, data = df_logit, family = binomial)
# Reporte de resultados
stargazer(fit1, fit2, fit3, fit4, type = "text",
column.labels = c("Family", "Mild", "Teen", "Adult"))
# 1. Calcular la probabilidad promedio (P_hat) para el grupo Teen/Moderate
avg_data <- df_logit %>% summarise(across(c(duration, log_budget, Z_FBlikes, D_USA, D_UK), mean))
z_score <- predict(fit3, newdata = avg_data, type = "link")
p_hat <- exp(z_score) / (1 + exp(z_score))
# 2. Calcular el efecto parcial de un cambio de 0.01 en log_budget
coef_log_budget <- coef(fit3)["log_budget"]
efecto_parcial_1porciento <- coef_log_budget * p_hat * (1 - p_hat) * 0.01
print(efecto_parcial_1porciento)
nuevo_caso <- data.frame(
duration = 100,
log_budget = mean(df_logit$log_budget),
D_USA = 0,
D_UK = 1,
Z_FBlikes = 2
)
prob_especifica <- predict(fit3, newdata = nuevo_caso, type = "response")
print(prob_especifica)
# Ejemplo para una matriz de confusión (Modelo Adult Content)
umbral <- 0.5
pred_adult <- as.numeric(predict(fit4, type = "response") > umbral)
table(Real = df_logit$y4, Predicho = pred_adult)
# Tabla de frecuencias
tabla_distribucion <- df_clean %>%
count(rating_group) %>%
mutate(porcentaje = n / sum(n) * 100)
print(tabla_distribucion)
